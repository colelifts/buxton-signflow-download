# Buxton SignFlow environment reference
#
# Keep production values in GitHub/Cloudflare/Supabase secrets. Do not commit real
# keys in this file.

# Current working Render backend fallback. Keep this until Cloudflare migration is
# fully verified.
SIGNFLOW_APP_URL=https://costco-contract-generator.onrender.com
COSTCO_CONTRACT_APP_URL=https://costco-contract-generator.onrender.com

# GitHub Releases for desktop installers and update checks.
SIGNFLOW_RELEASE_OWNER=colelifts
SIGNFLOW_RELEASE_REPO=buxton-signflow-download

# Cloudflare Pages frontend
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=buxton-signflow

# Cloudflare Workers API
CLOUDFLARE_WORKER_NAME=buxton-signflow-api
SIGNFLOW_API_BASE_URL=https://buxton-signflow-api.YOUR_SUBDOMAIN.workers.dev

# Cloudflare R2 storage
R2_BUCKET=buxton-signflow-files
R2_PUBLIC_BASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=Costco Home Remedies <contracts@your-domain.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=Costco Home Remedies <contracts@your-domain.com>

